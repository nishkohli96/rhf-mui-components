{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "lint": {
      "dependsOn": [],
      "cache": false
    },
    "lib:build": {
      "dependsOn": [],
      "cache": false,
      "outputs": ["dist/**"]
    },
    "build": {
      "dependsOn": ["^lib:build"],
      "outputs": ["build/**", "dist/**", ".next/**", "!.next/cache/**"]
    }
  }
}
