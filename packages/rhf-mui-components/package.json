{
  "name": "@nish1896/rhf-mui-components",
  "version": "3.2.1",
  "description": "A suite of 20+ production-ready react-hook-form components built with material-ui. Fully typed, tree-shakable, and optimized for enterprise-grade forms.",
  "author": "Nishant Kohli",
  "homepage": "https://rhf-mui-components.netlify.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/nishkohli96/rhf-mui-components"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown && cp package.json dist/ && cp README.md dist/ && cp .npmignore dist/",
    "lint": "eslint --fix ."
  },
  "type": "module",
  "sideEffects": false,
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@nish1896/eslint-flat-config": "^3.1.1",
    "eslint": "^9.39.2",
    "rimraf": "^6.0.1",
    "tsdown": "^0.20.3"
  },
  "peerDependencies": {
    "@mui/icons-material": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "@mui/material": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "@mui/x-date-pickers": "^6.0.0 || ^7.0.0 || ^8.0.0",
    "react-hook-form": "^7.0.0"
  },
  "exports": {
    "./package.json": {
      "import": "./package.json",
      "require": "./package.json"
    },
    ".": {
      "import": "./index.js",
      "require": "./index.js"
    },
    "./config": {
      "import": "./config/index.js",
      "require": "./config/index.js"
    },
    "./form-helpers": {
      "import": "./form-helpers/index.js",
      "require": "./form-helpers/index.js"
    },
    "./mui": {
      "import": "./mui/index.js",
      "require": "./mui/index.js"
    },
    "./mui/*": {
      "import": "./mui/*/index.js",
      "require": "./mui/*/index.js"
    },
    "./mui-pickers": {
      "import": "./mui-pickers/index.js",
      "require": "./mui-pickers/index.js"
    },
    "./mui-pickers/*": {
      "import": "./mui-pickers/*/index.js",
      "require": "./mui-pickers/*/index.js"
    },
    "./misc": {
      "import": "./misc/index.js",
      "require": "./misc/index.js"
    },
    "./misc/*": {
      "import": "./misc/*/index.js",
      "require": "./misc/*/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "./mui": [
        "./mui/index.d.ts"
      ],
      "./mui/*": [
        "./mui/*/index.d.ts"
      ],
      "./mui-pickers": [
        "./mui-pickers/index.d.ts"
      ],
      "./mui-pickers/*": [
        "./mui-pickers/*/index.d.ts"
      ],
      "./misc": [
        "./misc/index.d.ts"
      ],
      "./misc/*": [
        "./misc/*/index.d.ts"
      ],
      "./config": [
        "./config/index.d.ts"
      ],
      "./form-helpers": [
        "./form-helpers/index.d.ts"
      ]
    }
  },
  "keywords": [
    "react-hook-form",
    "mui",
    "material-ui",
    "mui-v7",
    "mui-v6",
    "mui-v5",
    "react forms",
    "form validation",
    "form components",
    "typescript",
    "component library",
    "react ui",
    "mui components",
    "react form library",
    "rhf"
  ]
}