  },
  "type": "module",
  "sideEffects": false,
  "devDependencies": {
    "@ckeditor/ckeditor5-core": "43.3.0",
    "@ckeditor/ckeditor5-react": "9.0.0",
    "@ckeditor/ckeditor5-utils": "43.3.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/system": "^7.3.9",
    "@mui/x-date-pickers": "^8.27.2",
    "@nish1896/eslint-flat-config": "^3.1.5",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "ckeditor5": "43.3.0",
    "eslint": "^9.39.4",
    "react": "^19.2.7",
    "react-color-palette": "7.3.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-international-phone": "^4.8.0",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@mui/icons-material": "^6.0.0 || ^7.0.0",
    "@mui/material": "^6.0.0 || ^7.0.0",
    "@mui/x-date-pickers": "^7.0.0 || ^8.0.0",
    "react-hook-form": "^7.0.0"
  },
  "exports": {
    "./package.json": "./dist/package.json",
    ".": "./dist/index.js",
    "./config": "./dist/config/index.js",
    "./form-helpers": "./dist/form-helpers/index.js",
    "./mui": "./dist/mui/index.js",
    "./mui/*": "./dist/mui/*/index.js",
